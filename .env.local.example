# =============================================================================
# RankingTank — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values before running locally.
# On Netlify, add these in: Site settings → Environment variables.
# Never commit .env.local to version control.

# -----------------------------------------------------------------------------
# Sanity CMS
# Get these from https://www.sanity.io/manage → your project → API
# -----------------------------------------------------------------------------

# Your Sanity project ID (visible in sanity.config.ts or the Manage dashboard)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# The Sanity dataset to use (typically "production")
NEXT_PUBLIC_SANITY_DATASET=production

# A Sanity API token with "Editor" or "Viewer" read permissions.
# Required for server-side data fetching (ISR / server components).
# Generate at: https://www.sanity.io/manage → project → API → Tokens
SANITY_API_TOKEN=your_sanity_api_token_here
